{
    "name": "@bytebender/nestjs-quickbooks",
    "version": "9.0.1",
    "keywords": [
        "nestjs",
        "quickbooks"
    ],
    "description": "An easy way to interact with the QuickBooks API in your NestJS applications.",
    "main": "dist/index.js",
    "repository": {
        "url": "https://github.com/bytebender/nestjs-quickbooks.git"
    },
    "scripts": {
        "build": "rimraf dist && nest build",
        "build:lib": "rimraf dist && nest build -p tsconfig.lib.json",
        "test": "npx jest",
        "copy:lib": "cp package.json .npmignore dist",
        "lint": "tslint -p tsconfig.json -c tslint.json",
        "publish-package": "npm run build:lib && npm run copy:lib && npm publish ./dist --access public",
        "publish-package:beta": "npm run publish-package -- --tag beta --access public",
        "publish-package:dry-run": "npm run publish-package -- --dry-run"
    },
    "author": "Byte Bender Apps",
    "license": "MIT",
    "directories": {
        "lib": "lib"
    },
    "jest": {
        "moduleFileExtensions": [
            "js",
            "json",
            "ts"
        ],
        "rootDir": "lib",
        "testRegex": ".spec.ts$",
        "transform": {
            "^.+\\.(t|j)s$": "ts-jest"
        },
        "coverageDirectory": "./coverage",
        "testEnvironment": "node"
    },
    "dependencies": {
        "@nestjs/axios": "^4.0.0",
        "@nestjs/schedule": "^5.0.1",
        "express": "^4.21.2",
        "form-data": "^4.0.2",
        "intuit-oauth": "^4.2.0",
        "rxjs": "^7.8.2"
    },
    "peerDependencies": {
        "@nestjs/common": "^11.0.1",
        "@nestjs/core": "^11.0.1"
    },
    "devDependencies": {
        "@nestjs/testing": "^11.0.10",
        "@types/express": "^5.0.0",
        "@types/jest": "^29.5.14",
        "@types/node": "^22.13.5",
        "@types/prettier": "^2.7.3",
        "@types/supertest": "^6.0.2",
        "eslint": "^9.21.0",
        "eslint-config-prettier": "^10.0.2",
        "eslint-plugin-prettier": "^5.2.3",
        "jest": "^29.7.0",
        "prettier": "^3.5.2",
        "rimraf": "^6.0.1",
        "supertest": "^7.0.0",
        "ts-jest": "^29.2.6",
        "typescript": "^5.7.3",
        "typescript-eslint": "^8.25.0"
    }
}
